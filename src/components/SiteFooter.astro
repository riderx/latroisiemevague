---
const nav = [
  { label: 'Accueil', href: '/' },
  { label: 'Substances', href: '/substances/' },
  { label: 'Microdosing', href: '/microdosing/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'À propos', href: '/a-propos/' },
  { label: 'Contact', href: '/contact/' },
]
---

<footer class="bg-[#333a40] text-white">
  <div class="mx-auto flex max-w-[1140px] flex-col gap-5 px-7 py-7 text-[14px] font-semibold md:flex-row md:items-center md:justify-between lg:px-0">
    <nav class="flex flex-wrap gap-x-4 gap-y-2" aria-label="Navigation pied de page">
      {nav.map((item) => <a href={item.href} class="text-white/90 transition-colors hover:text-white">{item.label}</a>)}
    </nav>
    <p class="text-white/90">© 2026 - La troisième vague. All rights reserved.</p>
  </div>
</footer>
