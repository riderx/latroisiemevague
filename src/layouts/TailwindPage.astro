---
import '../styles/global.css'
import SiteFooter from '../components/SiteFooter.astro'
import SiteHeader from '../components/SiteHeader.astro'

type Page = {
  id: string
  path: string
  title: string
  description: string
}

const { page, content } = Astro.props as { page: Page; content: string }
const canonical = new URL(page.path, 'https://latroisiemevague.com').toString()
const eyebrow = page.path.split('/').filter(Boolean).slice(0, 1).join(' / ')
---

<!doctype html>
<html lang="fr-FR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow" />
    <title>{page.title}</title>
    {page.description && <meta name="description" content={page.description} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/assets/uploads/2020/08/cropped-favicon-32x32.png" sizes="32x32" />
  </head>
  <body class="bg-white font-sans text-[#11183d] antialiased">
    <SiteHeader currentPath={page.path} />

    <main class="overflow-hidden">
      <section class="relative bg-white px-7 pb-20 pt-[250px] md:px-0 md:pb-24 md:pt-[250px]">
        <div class="pointer-events-none absolute right-[-180px] top-[-220px] h-[500px] w-[900px] rounded-bl-[55%] rounded-br-[30%] rounded-tl-[35%] bg-[#f0f2ff]"></div>
        <div class="pointer-events-none absolute right-[170px] top-[138px] hidden h-[225px] w-[360px] rotate-[18deg] rounded-[50%] bg-[#f0f2ff] md:block"></div>
        <div class="relative mx-auto max-w-[960px] text-center">
          {eyebrow && <p class="mb-6 text-[15px] font-bold uppercase text-[#56c8ff]">{eyebrow}</p>}
          <h1 class="text-pretty text-[38px] font-extrabold leading-[1.25] text-[#30395f] md:text-[58px]">{page.title}</h1>
          {page.description && <p class="mx-auto mt-7 max-w-[760px] text-[18px] font-medium leading-[1.65] text-[#11183d] md:text-[21px]">{page.description}</p>}
        </div>
      </section>

      <section class="relative px-7 pb-28 md:px-0">
        <div class="pointer-events-none absolute left-[-115px] top-4 h-[250px] w-[250px] rounded-full border border-[#dfe3ff]">
          <div class="absolute inset-9 rounded-full border border-[#ffd9bd]"></div>
          <div class="absolute inset-[72px] rounded-full border border-[#cff5c8]"></div>
        </div>
        <article class="prose ltv-content relative mx-auto max-w-[820px]" set:html={content} />
      </section>
    </main>

    <SiteFooter />
  </body>
</html>
