---
import '../styles/global.css'
import SiteCompactHeader from '../components/SiteCompactHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'

type Page = {
  id: string
  path: string
  title: string
  description: string
}

const { page, content } = Astro.props as { page: Page; content: string }
const canonical = new URL(page.path, 'https://latroisiemevague.com').toString()

const stripTags = (value: string) => value.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim()
let body = content.trim()
let pageHeading = page.title.split(' - ')[0]
let breadcrumbs = ''

const headingMatch = body.match(/^<h1[^>]*>([\s\S]*?)<\/h1>\s*/i)
if (headingMatch) {
  pageHeading = stripTags(headingMatch[1]) || pageHeading
  body = body.slice(headingMatch[0].length).trimStart()
}

const breadcrumbMatch = body.match(/^<ol[^>]*>([\s\S]*?)<\/ol>\s*/i)
if (breadcrumbMatch) {
  breadcrumbs = breadcrumbMatch[0]
  body = body.slice(breadcrumbMatch[0].length).trimStart()
}
body = body.replace(/<img([^>]*?)\sloading="lazy"([^>]*)>/i, '<img$1 loading="eager"$2>')
---

<!doctype html>
<html lang="fr-FR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow" />
    <title>{page.title}</title>
    {page.description && <meta name="description" content={page.description} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/assets/uploads/2020/08/cropped-favicon-32x32.png" sizes="32x32" />
  </head>
  <body class="bg-white font-sans text-[#11183d] antialiased">
    <SiteCompactHeader currentPath={page.path} />

    <main>
      <section class="bg-[#f6f7f9]">
        <div class="mx-auto max-w-[1100px] px-5 pb-[7px] pt-[21px] lg:px-0">
          <h1 class="text-[42px] font-bold leading-[1.2] tracking-[0] text-[#252a31]">{pageHeading}</h1>
          {breadcrumbs && <nav class="ltv-breadcrumb mt-3" aria-label="Breadcrumb" set:html={breadcrumbs} />}
        </div>
      </section>

      <section class="px-5 pb-20 pt-[106px] md:pt-[220px] md:pb-24 lg:px-0">
        <div class="mx-auto max-w-[1100px]">
          <article class="prose ltv-content ltv-guide-content max-w-[760px] lg:ml-[26px]" set:html={body} />
        </div>
      </section>
    </main>

    <SiteFooter />
  </body>
</html>
