---
import { readFile } from 'node:fs/promises'
import path from 'node:path'
import '../styles/site.css'

type Page = {
  id: string
  path: string
  title: string
  description: string
  bodyClass: string
}

const { page } = Astro.props as { page: Page }
const canonical = new URL(page.path, 'https://latroisiemevague.com').toString()
const contentDir = path.join(process.cwd(), 'page-content/pages', page.id)
const [headHtml, bodyHtml] = await Promise.all([
  readFile(path.join(contentDir, 'head.html'), 'utf8'),
  readFile(path.join(contentDir, 'body.html'), 'utf8'),
])
---

<!doctype html>
<html lang="fr-FR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <title>{page.title}</title>
    {page.description && <meta name="description" content={page.description} />}
    <link rel="canonical" href={canonical} />
    <Fragment set:html={headHtml} />
  </head>
  <body class={page.bodyClass}>
    <Fragment set:html={bodyHtml} />
    <script is:inline>
      (() => {
        const closeMenus = () => {
          document.querySelectorAll('.raven-nav-menu-mobile').forEach((menu) => {
            menu.classList.remove('ltv-menu-open')
          })
        }

        document.addEventListener('click', (event) => {
          const target = event.target
          if (!(target instanceof Element)) return

          if (target.closest('.raven-nav-menu-toggle, .raven-nav-menu-toggle-button')) {
            event.preventDefault()
            document.querySelectorAll('.raven-nav-menu-mobile').forEach((menu) => {
              menu.classList.add('ltv-menu-open')
            })
          }

          if (target.closest('.raven-nav-menu-close-button')) {
            event.preventDefault()
            closeMenus()
          }
        })

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') closeMenus()
        })
      })()
    </script>
  </body>
</html>
