{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "latroisiemevague",
  "compatibility_date": "2026-06-23",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "none"
  },
  "workers_dev": false,
  "routes": [
    {
      "pattern": "latroisiemevague.com",
      "custom_domain": true
    },
    {
      "pattern": "www.latroisiemevague.com",
      "custom_domain": true
    }
  ]
}
